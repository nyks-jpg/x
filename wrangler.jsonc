{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "x",
  "main": "src/index.js",
  "compatibility_date": "2026-05-17",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "proje",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI"
  }
}
